program: (structDecl | funcDecl)* EOF;

structDecl: STRUCT ID LBRACE structMember* RBRACE SEMI;
structMember: typeSpecNoVoid ID SEMI;

funcDecl
    : returnType ID LPAREN paramList? RPAREN block
    | ID LPAREN paramList? RPAREN block
    ;

returnType: typeSpec;
typeSpec: primitiveType | ID;
primitiveType: INT | FLOAT | STRING | VOID;
typeSpecNoVoid: primitiveNoVoid | ID;
primitiveNoVoid: INT | FLOAT | STRING;

paramList: param (COMMA param)*;
param: typeSpecNoVoid ID;

block: LBRACE statementList RBRACE;
statementList: statement*;

statement
    : varDeclStmt
    | block
    | ifStmt
    | whileStmt
    | forStmt
    | switchStmt
    | breakStmt
    | continueStmt
    | returnStmt
    | exprStmt
    ;

varDeclStmt: varDecl SEMI;
varDecl
    : AUTO ID (ASSIGN expr)?
    | typeSpecNoVoid ID (ASSIGN expr)?
    ;

ifStmt: IF LPAREN expr RPAREN statement (ELSE statement)?;
whileStmt: WHILE LPAREN expr RPAREN statement;

forStmt: FOR LPAREN forInit? SEMI forCond? SEMI forUpdate? RPAREN statement;
forInit: varDecl | expr;
forCond: expr;
forUpdate: expr;

switchStmt: SWITCH LPAREN expr RPAREN LBRACE switchSection* defaultSection? switchSection* RBRACE;
switchSection: caseLabel+ statementList;
caseLabel: CASE expr COLON;
defaultSection: DEFAULT COLON statementList;

breakStmt: BREAK SEMI;
continueStmt: CONTINUE SEMI;
returnStmt: RETURN expr? SEMI;
exprStmt: expr SEMI;

expr: assignmentExpr;
assignmentExpr: logicalOrExpr (ASSIGN assignmentExpr)?;
logicalOrExpr: logicalAndExpr (OR logicalAndExpr)*;
logicalAndExpr: equalityExpr (AND equalityExpr)*;
equalityExpr: relationalExpr ((EQ | NEQ) relationalExpr)*;
relationalExpr: additiveExpr ((LT | LE | GT | GE) additiveExpr)*;
additiveExpr: multiplicativeExpr ((ADD | SUB) multiplicativeExpr)*;
multiplicativeExpr: unaryExpr ((MUL | DIV | MOD) unaryExpr)*;

unaryExpr
    : (NOT | ADD | SUB | INC | DEC) unaryExpr
    | postfixExpr
    ;

postfixExpr
    : ID callSuffix? (DOT ID callSuffix?)* (INC | DEC)?
    | primaryExprNoId (DOT ID callSuffix?)* (INC | DEC)?
    ;

primaryExprNoId
    : literal
    | LPAREN expr RPAREN
    | structLiteral
    ;

callSuffix: LPAREN argList? RPAREN;
argList: expr (COMMA expr)*;

structLiteral: LBRACE exprList? RBRACE;
exprList: expr (COMMA expr)*;

literal: INT_LIT | FLOAT_LIT | STRING_LIT;

