grammar TyC;

@lexer::header {
from lexererr import *
}

@lexer::members {
# Convert special lexer tokens into assignment-required exceptions.
# Tests consume exception messages, so these mappings are critical.
def emit(self):
    tk = self.type
    if tk == self.UNCLOSE_STRING:       
        result = super().emit();
        raise UncloseString(result.text);
    elif tk == self.ILLEGAL_ESCAPE:
        result = super().emit();
        raise IllegalEscape(result.text);
    elif tk == self.ERROR_TOKEN:
        result = super().emit();
        raise ErrorToken(result.text); 
    else:
        return super().emit();
}

options{
	language=Python3;
}

// =========================
// Parser Rules
// =========================

// A program is a sequence of top-level struct/function declarations.
program: (structDecl | funcDecl)* EOF;

// struct Point { int x; int y; };
structDecl: STRUCT ID LBRACE structMember* RBRACE SEMI;
// Struct members require explicit non-void types.
structMember: typeSpecNoVoid ID SEMI;

// Function declaration supports:
// 1) explicit return type: int add(...) { ... }
// 2) inferred return type: add(...) { ... }
funcDecl
    : returnType ID LPAREN paramList? RPAREN block
    | ID LPAREN paramList? RPAREN block
    ;

// Type grammar:
// - primitive: int/float/string/void
// - user type: struct name (ID)
returnType: typeSpec;
typeSpec: primitiveType | ID;
primitiveType: INT | FLOAT | STRING | VOID;
// Variables/params/members cannot use void.
typeSpecNoVoid: primitiveNoVoid | ID;
primitiveNoVoid: INT | FLOAT | STRING;

// Function parameter list: (type name, type name, ...)
paramList: param (COMMA param)*;
param: typeSpecNoVoid ID;

// A block always contains a (possibly empty) statement list.
block: LBRACE statementList RBRACE;
statementList: statement*;

// Supported statements in TyC.
statement
    : varDeclStmt
    | block
    | ifStmt
    | whileStmt
    | forStmt
    | switchStmt
    | breakStmt
    | continueStmt
    | returnStmt
    | exprStmt
    ;

varDeclStmt: varDecl SEMI;
// Variable declarations:
// - auto x; / auto x = expr;
// - int x; / int x = expr; (also float/string/struct type)
varDecl
    : AUTO ID (ASSIGN expr)?
    | typeSpecNoVoid ID (ASSIGN expr)?
    ;

// Classic control flow forms.
ifStmt: IF LPAREN expr RPAREN statement (ELSE statement)?;
whileStmt: WHILE LPAREN expr RPAREN statement;

// for(init; cond; update) statement
// Spec-constrained:
// - init: variable declaration or assignment
// - update: assignment or ++/--
forStmt: FOR LPAREN forInit? SEMI forCond? SEMI forUpdate? RPAREN statement;
forInit: varDecl | forAssign;
forCond: expr;
forUpdate: forAssign | forIncDec;
// Right-associative assignment expression is reused here.
forAssign: lvalue ASSIGN assignmentExpr;
// Update can be either prefix or postfix inc/dec.
forIncDec: prefixIncDec | lvalue (INC | DEC);

// Switch allows:
// - zero or more case groups
// - optional single default
// - additional case groups after default (default can appear in middle)
switchStmt: SWITCH LPAREN expr RPAREN LBRACE switchSection* defaultSection? switchSection* RBRACE;
// One section may have multiple case labels sharing one statement list.
switchSection: caseLabel+ statementList;
caseLabel: CASE expr COLON;
defaultSection: DEFAULT COLON statementList;

breakStmt: BREAK SEMI;
continueStmt: CONTINUE SEMI;
returnStmt: RETURN expr? SEMI;
exprStmt: expr SEMI;

// Expression precedence (low -> high starts here).
expr: assignmentExpr;
// Assignment is restricted to lvalue on LHS.
assignmentExpr: lvalue ASSIGN assignmentExpr | logicalOrExpr;
logicalOrExpr: logicalAndExpr (OR logicalAndExpr)*;
logicalAndExpr: equalityExpr (AND equalityExpr)*;
equalityExpr: relationalExpr ((EQ | NEQ) relationalExpr)*;
relationalExpr: additiveExpr ((LT | LE | GT | GE) additiveExpr)*;
additiveExpr: multiplicativeExpr ((ADD | SUB) multiplicativeExpr)*;
multiplicativeExpr: unaryExpr ((MUL | DIV | MOD) unaryExpr)*;

// Prefix operators:
// - ++/-- restricted to lvalue only
// - !, +, - can apply to any unaryExpr
unaryExpr
    : prefixIncDec
    | (NOT | ADD | SUB) unaryExpr
    | postfixExpr
    ;

prefixIncDec: (INC | DEC) lvalue;

// Postfix layer:
// - lvalue with optional postfix ++/--
// - plain function call by identifier only (ID(...))
// - other primaries with chained member access
// Note: method-style calls like p.x() are intentionally disallowed.
postfixExpr
    : lvalue (INC | DEC)?
    | ID callSuffix (DOT ID)*
    | primaryExprNoId (DOT ID)*
    ;

// Assignable forms:
// - variable
// - member chains from variable/call/parenthesized/struct literal roots
lvalue
    : ID
    | ID (DOT ID)+
    | ID callSuffix (DOT ID)+
    | primaryExprNoId (DOT ID)+
    ;

primaryExprNoId
    : literal
    | LPAREN expr RPAREN
    | structLiteral
    ;

// Function call arguments.
callSuffix: LPAREN argList? RPAREN;
argList: expr (COMMA expr)*;

// Struct literal used in initialization/arguments.
structLiteral: LBRACE exprList? RBRACE;
exprList: expr (COMMA expr)*;

literal: INT_LIT | FLOAT_LIT | STRING_LIT;

// =========================
// Lexer Rules
// =========================

// Keywords
AUTO: 'auto';
BREAK: 'break';
CASE: 'case';
CONTINUE: 'continue';
DEFAULT: 'default';
ELSE: 'else';
FLOAT: 'float';
FOR: 'for';
IF: 'if';
INT: 'int';
RETURN: 'return';
STRING: 'string';
STRUCT: 'struct';
SWITCH: 'switch';
VOID: 'void';
WHILE: 'while';

// Operators
INC: '++';
DEC: '--';
EQ: '==';
NEQ: '!=';
LE: '<=';
GE: '>=';
OR: '||';
AND: '&&';
ADD: '+';
SUB: '-';
MUL: '*';
DIV: '/';
MOD: '%';
LT: '<';
GT: '>';
NOT: '!';
ASSIGN: '=';
DOT: '.';

// Separators
LPAREN: '(';
RPAREN: ')';
LBRACE: '{';
RBRACE: '}';
SEMI: ';';
COMMA: ',';
COLON: ':';

// Literals
// Float forms:
// - 1.0, 1., .5, 1e4, 1.2e-3
FLOAT_LIT
    : DIGIT+ '.' DIGIT* EXP?
    | '.' DIGIT+ EXP?
    | DIGIT+ EXP
    ;

INT_LIT: DIGIT+;

// Strip surrounding quotes from valid string literal token text.
STRING_LIT
    : '"' (ESC_SEQ | ~["\\\r\n])* '"' { self.text = self.text[1:-1] }
    ;

ID: LETTER (LETTER | DIGIT)*;

// Comments and whitespace
// Line comment: from // to end-of-line.
LINE_COMMENT: '//' ~[\r\n]* -> skip;
// Block comment: consume until */; if missing, consume until EOF.
BLOCK_COMMENT: '/*' .*? ('*/' | EOF) -> skip;
// Whitespace skipped by lexer.
WS: [ \t\r\n\f]+ -> skip;

// Error handling for strings
// Illegal escape:
// keep content without opening quote and include illegal escape tail.
ILLEGAL_ESCAPE
    : '"' (ESC_SEQ | ~["\\\r\n])* '\\' ~[btnfr"\\\r\n]
      { self.text = self.text[1:] }
    ;

// Unclosed string:
// remove opening quote and trim trailing newline/CR if present.
UNCLOSE_STRING
    : '"' (ESC_SEQ | ~["\\\r\n])* ( '\\' ('\r'? '\n' | EOF) | '\r'? '\n' | EOF )
      {
        text = self.text[1:]
        if text.endswith('\r\n'):
            self.text = text[:-2]
        elif text.endswith('\n') or text.endswith('\r'):
            self.text = text[:-1]
        else:
            self.text = text
      }
    ;

// Catch-all invalid character.
ERROR_TOKEN: .;

// Fragments
fragment DIGIT: [0-9];
fragment LETTER: [a-zA-Z_];
fragment EXP: [eE] [+-]? DIGIT+;
fragment ESC_SEQ: '\\' [btnfr"\\];

